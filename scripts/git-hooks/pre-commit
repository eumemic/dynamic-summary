#!/bin/bash
# Git pre-commit hook for RagZoom
# Runs tests (excluding slow ones) and linting checks in parallel

echo "Running pre-commit checks..."

# Get the list of modified Python files
modified_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$')

# Function to run tests
run_tests() {
    echo "[Tests] Starting..."
    pytest tests/ -v --tb=short -m "not slow and not integration" -n 8
    local result=$?
    if [ $result -ne 0 ]; then
        echo "[Tests] ❌ Failed!"
        return 1
    else
        echo "[Tests] ✅ Passed!"
        return 0
    fi
}

# Function to run ruff
run_ruff() {
    if command -v ruff &> /dev/null && [ -n "$modified_files" ]; then
        echo "[Ruff] Starting auto-fixing..."
        ruff check ragzoom/ tests/ --fix
        local result=$?
        if [ $result -ne 0 ]; then
            echo "[Ruff] ❌ Found issues that could not be auto-fixed."
            return 1
        else
            echo "[Ruff] ✅ Passed!"
            return 0
        fi
    fi
    return 0
}

# Function to run black
run_black() {
    if command -v black &> /dev/null && [ -n "$modified_files" ]; then
        echo "[Black] Starting auto-formatting..."
        black ragzoom/ tests/
        local result=$?
        if [ $result -ne 0 ]; then
            echo "[Black] ❌ Formatting failed."
            return 1
        else
            echo "[Black] ✅ Passed!"
            return 0
        fi
    fi
    return 0
}

# Function to run mypy
run_mypy() {
    if command -v dmypy &> /dev/null && [ -n "$modified_files" ]; then
        echo "[Mypy] Starting type checking with daemon..."
        # Use dmypy run which starts daemon if needed and runs check
        dmypy run -- ragzoom --ignore-missing-imports --no-error-summary --check-untyped-defs
        local result=$?
        if [ $result -ne 0 ]; then
            echo "[Mypy] ❌ Failed! Type errors found"
            return $result  # Return the actual error code
        else
            echo "[Mypy] ✅ Passed!"
            return 0
        fi
    elif command -v mypy &> /dev/null && [ -n "$modified_files" ]; then
        # Fallback to regular mypy if dmypy not available
        echo "[Mypy] Starting type checking..."
        mypy ragzoom --ignore-missing-imports --no-error-summary --check-untyped-defs
        local result=$?
        if [ $result -ne 0 ]; then
            echo "[Mypy] ❌ Failed! Type errors found"
            return $result  # Return the actual error code
        else
            echo "[Mypy] ✅ Passed!"
            return 0
        fi
    fi
    return 0
}

# Create temporary files for storing results
tmpdir=$(mktemp -d)
trap "rm -rf $tmpdir" EXIT

# Run all checks in parallel
(run_tests; echo $? > "$tmpdir/tests.result") &
pid_tests=$!

(run_ruff; echo $? > "$tmpdir/ruff.result") &
pid_ruff=$!

(run_black; echo $? > "$tmpdir/black.result") &
pid_black=$!

(run_mypy; echo $? > "$tmpdir/mypy.result") &
pid_mypy=$!

# Wait for all background jobs to complete
echo ""
echo "Running tests, ruff, black, and mypy in parallel..."
echo ""

wait $pid_tests $pid_ruff $pid_black $pid_mypy

# Re-add any files that were auto-formatted
echo ""
echo "Adding any auto-fixed files to the commit..."
git add $modified_files

# Check results
failed=0

# Check test results
if [ -f "$tmpdir/tests.result" ] && [ "$(cat "$tmpdir/tests.result")" -ne 0 ]; then
    failed=1
fi

# Check ruff results
if [ -f "$tmpdir/ruff.result" ] && [ "$(cat "$tmpdir/ruff.result")" -ne 0 ]; then
    failed=1
fi

# Check black results
if [ -f "$tmpdir/black.result" ] && [ "$(cat "$tmpdir/black.result")" -ne 0 ]; then
    failed=1
fi

# Check mypy results
if [ -f "$tmpdir/mypy.result" ] && [ "$(cat "$tmpdir/mypy.result")" -ne 0 ]; then
    failed=1
fi

echo ""
if [ $failed -eq 0 ]; then
    echo "✅ All pre-commit checks passed!"
    exit 0
else
    echo "❌ Pre-commit checks failed! See above for details."
    exit 1
fi