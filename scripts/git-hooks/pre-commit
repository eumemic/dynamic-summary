#!/bin/bash
# Git pre-commit hook for RagZoom
# Runs tests (excluding slow ones) and linting checks

echo "Running pre-commit checks..."

# Get the list of modified Python files
modified_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$')

# Run tests excluding slow and integration tests
echo "Running fast tests..."
pytest tests/ -v --tb=short -m "not slow and not integration" -n 8

# Capture the test exit code
test_result=$?

if [ $test_result -ne 0 ]; then
    echo ""
    echo "❌ Tests failed! Commit aborted."
    echo "Fix the failing tests before committing."
    exit 1
fi

echo "✅ Tests passed!"

# Run linting if Python files were modified
if [ -n "$modified_files" ]; then
    echo ""
    echo "Running linting checks..."
    
    # Run ruff
    if command -v ruff &> /dev/null; then
        echo "Running ruff..."
        ruff check ragzoom/ tests/
        if [ $? -ne 0 ]; then
            echo "❌ Ruff found issues! Commit aborted."
            echo "Run 'ruff check ragzoom/ tests/ --fix' to auto-fix some issues."
            exit 1
        fi
        echo "✅ Ruff passed!"
    fi
    
    # Run black check
    if command -v black &> /dev/null; then
        echo "Running black..."
        black --check ragzoom/ tests/
        if [ $? -ne 0 ]; then
            echo "❌ Black formatting issues found! Commit aborted."
            echo "Run 'black ragzoom/ tests/' to auto-format."
            exit 1
        fi
        echo "✅ Black passed!"
    fi
fi

# Optional: Run type checking (warning only)
if command -v mypy &> /dev/null && [ -n "$modified_files" ]; then
    echo ""
    echo "Running type checking..."
    mypy ragzoom --ignore-missing-imports --no-error-summary 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "⚠️  Type checking found issues (commit will continue)"
    else
        echo "✅ Type checking passed!"
    fi
fi

echo ""
echo "✅ All pre-commit checks passed!"
exit 0