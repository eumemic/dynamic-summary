{
  "target_chunk_tokens": 200,
  "summary_model": "gpt-5-nano",
  "embedding_model": "text-embedding-3-small",
  "retry_threshold": 0.2,
  "max_retries": 3,
  "embedding_batch_size": 100,
  "use_anti_verbatim_vaccine": true,
  "preceding_context": {
    "leaf": {
      "num_seeds": 3,
      "verbatim_tokens": 2000,
      "min_forest_completeness": 1.0,
      "verbatim_nodes_only": false
    },
    "inner": {
      "num_seeds": 0,
      "verbatim_tokens": 2000,
      "min_forest_completeness": 0.0,
      "verbatim_nodes_only": true
    }
  }
}
