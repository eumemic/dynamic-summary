#!/usr/bin/env python3
"""Run the LoCoMo benchmark against the RagZoom dev server."""

from __future__ import annotations

import argparse
import asyncio
import logging
from pathlib import Path


def main() -> None:
    parser = argparse.ArgumentParser(
        description="LoCoMo benchmark evaluation for RagZoom"
    )
    parser.add_argument(
        "--data",
        type=Path,
        default=None,
        help="Path to locomo10.json (required unless --rejudge is used)",
    )
    parser.add_argument(
        "--answer-model",
        default="gpt-4o-mini",
        help="Model for answer generation (default: gpt-4o-mini)",
    )
    parser.add_argument(
        "--judge-model",
        default="gpt-4.1",
        help="Model for LLM-as-Judge (default: gpt-4.1, matching Letta Leaderboard)",
    )
    parser.add_argument(
        "--budgets",
        nargs="+",
        type=int,
        default=[500, 1000, 2000, 4000, 8000],
        help="Token budgets to sweep (default: 500 1000 2000 4000 8000)",
    )
    parser.add_argument(
        "--output-dir",
        type=Path,
        default=Path("locomo_results"),
        help="Output directory for results (default: locomo_results/)",
    )
    parser.add_argument(
        "--server",
        default="127.0.0.1:50052",
        help="RagZoom server address (default: 127.0.0.1:50052, dev server)",
    )
    parser.add_argument(
        "--max-concurrent",
        type=int,
        default=10,
        help="Max concurrent LLM calls (default: 10)",
    )
    parser.add_argument(
        "--skip-ingest",
        action="store_true",
        help="Skip ingestion (use if documents are already indexed)",
    )
    parser.add_argument(
        "--sample",
        type=int,
        default=None,
        help="Evaluate a random sample of N questions (reproducible, seed=42)",
    )
    parser.add_argument(
        "--f1-only",
        action="store_true",
        help="Skip LLM judge, compute token F1 only (saves judge API costs)",
    )
    parser.add_argument(
        "--rejudge",
        type=Path,
        default=None,
        help="Re-judge answers from a previous results.json (no server needed)",
    )
    parser.add_argument(
        "--max-iterations",
        type=int,
        default=1,
        help="Max recall calls per question (1=single-shot, >1=agentic zoom, default: 1)",
    )
    parser.add_argument(
        "--agent-model",
        default=None,
        help="Model for agentic evaluation (defaults to --answer-model)",
    )
    parser.add_argument(
        "--isolated-server",
        action="store_true",
        help="Spawn an isolated RagZoom server for the benchmark (port 50053, temp state dir)",
    )
    parser.add_argument(
        "-v",
        "--verbose",
        action="store_true",
        help="Enable verbose logging",
    )
    args = parser.parse_args()

    if args.rejudge is None and args.data is None:
        parser.error("--data is required unless --rejudge is used")

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(asctime)s %(levelname)-5s %(name)s: %(message)s",
        datefmt="%H:%M:%S",
    )

    # Import here to avoid slow imports when just showing --help
    from ragzoom.evaluation.locomo.report import save_json, save_markdown
    from ragzoom.evaluation.locomo.runner import (
        LoCoMoConfig,
        rejudge,
        run_benchmark,
    )

    config = LoCoMoConfig(
        data_path=args.data or Path("/unused"),
        server_address=args.server,
        answer_model=args.answer_model,
        judge_model=args.judge_model,
        budgets=args.budgets,
        max_concurrent=args.max_concurrent,
        output_dir=args.output_dir,
        skip_ingest=args.skip_ingest,
        sample_size=args.sample,
        f1_only=args.f1_only,
        rejudge_path=args.rejudge,
        max_iterations=args.max_iterations,
        agent_model=args.agent_model,
        use_isolated_server=args.isolated_server,
    )

    if config.rejudge_path is not None:
        report = asyncio.run(rejudge(config))
    else:
        report = asyncio.run(run_benchmark(config))

    args.output_dir.mkdir(parents=True, exist_ok=True)
    json_path = args.output_dir / "results.json"
    md_path = args.output_dir / "report.md"

    save_json(report, json_path)
    save_markdown(report, md_path)

    print(f"\nResults saved to {json_path} and {md_path}")

    # Print summary to stdout
    has_accuracy = any(
        bp.overall_accuracy is not None for bp in report.budget_curve
    )
    if has_accuracy:
        print(f"\n{'Budget':>8}  {'Accuracy':>8}  {'F1':>6}")
        print("-" * 28)
        for bp in report.budget_curve:
            acc = f"{bp.overall_accuracy * 100:>7.1f}%" if bp.overall_accuracy is not None else "    N/A"
            print(f"{bp.budget_tokens:>8,}  {acc}  {bp.overall_f1:>.3f}")
    else:
        print(f"\n{'Budget':>8}  {'F1':>6}")
        print("-" * 18)
        for bp in report.budget_curve:
            print(f"{bp.budget_tokens:>8,}  {bp.overall_f1:>.3f}")


if __name__ == "__main__":
    main()
