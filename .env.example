# RagZoom Configuration
# Copy this file to .env and fill in your values

# Required: OpenAI API Key
OPENAI_API_KEY=your-key-here

# Optional: Override default configuration
# RAGZOOM_BUDGET_TOKENS=8000
# RAGZOOM_LEAF_TOKENS=200
# RAGZOOM_MMR_LAMBDA=0.7
# RAGZOOM_EMBEDDING_MODEL=text-embedding-3-small
# RAGZOOM_SUMMARY_MODEL=gpt-4o
# RAGZOOM_LOG_LEVEL=INFO

# Optional: Storage paths (defaults to project directory)
# RAGZOOM_CHROMA_PERSIST_DIRECTORY=./chroma_db
# RAGZOOM_SQLITE_DATABASE_URL=sqlite:///ragzoom.db