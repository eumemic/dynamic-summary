#!/bin/bash
set -euo pipefail

# Find the highest existing worktree-N number
WORKTREES_DIR="worktrees"
mkdir -p "$WORKTREES_DIR"

# Find highest numbered worktree
HIGHEST=0
for dir in "$WORKTREES_DIR"/worktree-*; do
    if [[ -d "$dir" ]]; then
        NUM=$(basename "$dir" | sed 's/worktree-//')
        if [[ "$NUM" =~ ^[0-9]+$ ]] && (( NUM > HIGHEST )); then
            HIGHEST=$NUM
        fi
    fi
done

# Increment for new worktree
NEXT=$((HIGHEST + 1))
WORKTREE_NAME="worktree-$NEXT"
WORKTREE_PATH="$WORKTREES_DIR/$WORKTREE_NAME"

# Ensure we're on master and up to date
echo "Updating master branch..."
git checkout master
git pull

# Create the worktree with its own tracking branch
echo "Creating $WORKTREE_NAME..."

# First check if this worktree is already registered
if git worktree list | grep -q "$WORKTREE_PATH"; then
    echo "Worktree already registered at $WORKTREE_PATH, cleaning up..."
    git worktree remove "$WORKTREE_PATH" --force 2>/dev/null || true
fi

# Check if branch already exists
if git show-ref --verify --quiet "refs/heads/$WORKTREE_NAME"; then
    echo "Branch $WORKTREE_NAME already exists, checking for uncommitted changes..."
    
    # Check if there are uncommitted changes on the branch
    if git worktree list --porcelain | grep -q "$WORKTREE_NAME" && [ -d "$WORKTREE_PATH" ]; then
        # Worktree exists, check for uncommitted changes
        if [ -n "$(cd "$WORKTREE_PATH" 2>/dev/null && git status --porcelain)" ]; then
            echo "⚠️  WARNING: Uncommitted changes detected in $WORKTREE_PATH"
            echo "    Resetting the branch will lose these changes."
            read -p "    Continue anyway? (y/N) " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo "Aborted."
                exit 1
            fi
        fi
    fi
    
    echo "Resetting $WORKTREE_NAME to master..."
    git branch -f "$WORKTREE_NAME" master
    git worktree add "$WORKTREE_PATH" "$WORKTREE_NAME" 2>/dev/null || echo "Worktree already exists at $WORKTREE_PATH"
else
    git worktree add -b "$WORKTREE_NAME" "$WORKTREE_PATH" master
fi

# Set up branch to track master
echo "Setting up $WORKTREE_NAME to track origin/master..."
cd "$WORKTREE_PATH"
if git branch --set-upstream-to=origin/master "$WORKTREE_NAME"; then
    echo "✓ Branch tracking configured successfully"
else
    echo "⚠️  Warning: Failed to set up branch tracking"
    echo "  You can manually set it later with: git branch --set-upstream-to=origin/master"
fi
cd - > /dev/null

# Symlink .env if it exists
if [[ -f .env ]]; then
    echo "Symlinking .env..."
    ln -s "../../.env" "$WORKTREE_PATH/.env"
fi

# Symlink venv if it exists
if [[ -d venv ]]; then
    echo "Symlinking venv..."
    ln -s "../../venv" "$WORKTREE_PATH/venv"
fi

# Initialize submodules if they exist
if [[ -f .gitmodules ]]; then
    echo "Initializing submodules..."
    cd "$WORKTREE_PATH"
    git submodule init
    git submodule update
    cd - > /dev/null
fi

echo ""
echo "✅ Worktree created at: $WORKTREE_PATH"
echo ""
echo "To start working in this isolated workspace:"
echo "  cd $WORKTREE_PATH"
echo "  claude"