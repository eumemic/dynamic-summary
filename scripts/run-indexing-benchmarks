#!/bin/bash
# Run indexing benchmarks with telemetry comparison and visualization
# Usage: ./run-indexing-benchmarks --baseline <baseline.json> --output-dir <dir> [other_options] <document>
#
# This script:
# 1. Runs indexing with telemetry, logging output to a file
# 2. Concurrently generates comparison report and visualization
#
# Options:
#   --baseline <file>    Baseline telemetry JSON file for comparison
#   --output-dir <dir>   Directory for output files (telemetry, logs, visualizations)
#   All other options are passed through to the indexing command

set -e  # Exit on error
set -o pipefail  # Also exit on pipe failures

# Generate timestamp for this run
TIMESTAMP=$(date '+%Y%m%d_%H%M%S')

# Global variable to track created database for cleanup
CREATED_DB_NAME=""

# Cleanup function for error handling
cleanup_benchmark_db() {
    if [ -n "$CREATED_DB_NAME" ]; then
        echo ""
        echo "🧹 Cleaning up benchmark database: $CREATED_DB_NAME"
        # Use environment variable to avoid shell injection
        CLEANUP_DB_NAME="$CREATED_DB_NAME" python -c "
from ragzoom.db_utils import drop_temp_database
import os
try:
    drop_temp_database(os.environ['CLEANUP_DB_NAME'])
    print(f'✅ Cleaned up database: {os.environ[\"CLEANUP_DB_NAME\"]}')
except Exception as e:
    print(f'⚠️ Cleanup failed: {e}', file=__import__('sys').stderr)
" 2>&1
    fi
}

# Set trap for cleanup on exit
trap cleanup_benchmark_db EXIT INT TERM

# Check required dependencies
check_dependencies() {
    local missing_deps=()
    
    # Check for jq
    if ! command -v jq &> /dev/null; then
        missing_deps+=("jq")
    fi
    
    # Check for Python
    if ! command -v python &> /dev/null && ! command -v python3 &> /dev/null; then
        missing_deps+=("python")
    fi
    
    # Check for ragzoom module
    if ! python -c "import ragzoom" 2>/dev/null; then
        missing_deps+=("ragzoom (Python module)")
    fi
    
    # Check for telemetry dependencies if visualization is requested
    # We'll check this later when we know if visualization is needed
    
    if [ ${#missing_deps[@]} -gt 0 ]; then
        echo "Error: Missing required dependencies:"
        printf ' - %s\n' "${missing_deps[@]}"
        echo ""
        echo "Please install missing dependencies:"
        echo "  - jq: brew install jq (macOS) or apt-get install jq (Linux)"
        echo "  - ragzoom: pip install ragzoom"
        exit 1
    fi
}

# Check dependencies early
check_dependencies

# Function to display help
show_help() {
    cat << EOF
Usage: $0 [--baseline <baseline.json>] [--output-dir <dir>] [document] [options]

Run indexing benchmarks with telemetry comparison and visualization.

ITERATIVE WORKFLOW (recommended):
    After the first run, each subsequent run automatically uses the previous run as baseline:
    
    # First run (needs telemetry.json or --baseline)
    $0
    
    # Subsequent runs (each compares against previous)
    $0 && open benchmarks/latest/visualization.png
    
    # Make code changes, then run again to see impact
    $0 && open benchmarks/latest/visualization.png

Options:
    --baseline <file>      Baseline telemetry JSON file 
                          Default search order:
                          1. benchmarks/latest/telemetry.json (previous run)
                          2. ./telemetry.json (current directory)
                          3. <repo_root>/telemetry.json (if in worktree)
    --output-dir <dir>     Directory for output files
                          Default: benchmarks/<timestamp> (e.g., benchmarks/20250815_163448)
    --database <url>       PostgreSQL database URL to use
                          If provided, skips Docker PostgreSQL setup
                          Example: postgresql+psycopg://user:pass@host:5432/db
    --help                 Show this help message and exit
    
Document:
    If not specified, will auto-detect from baseline's document_id in test_data/
    
Additional Options:
    All other options are passed through to the ragzoom index command.
    The script automatically:
    - Adds: --telemetry --validate --debug --no-progress
    - Extracts target_chunk_tokens from baseline (for fair comparison)
    - Uses current default_config.json for all other settings (to test improvements)

Output Structure:
    benchmarks/
    ├── 20250815_163448/          # Timestamped run directory
    │   ├── benchmark_db.txt      # PostgreSQL database name used for indexing
    │   ├── telemetry.json        # Telemetry data (becomes next baseline)
    │   ├── log.txt               # Full indexing logs with debug output
    │   ├── comparison.md         # Markdown comparison report
    │   └── visualization.png     # Visual side-by-side comparison
    └── latest/                   # Symlink to most recent run

Examples:
    $0                                              # Use all defaults (iterative mode)
    $0 document.txt                                 # Override document only
    $0 --baseline other.json                        # Override baseline
    $0 --output-dir custom/dir document.txt        # Custom output (disables latest symlink)

EOF
    exit 0
}

# Initialize variables
BASELINE=""
OUTPUT_DIR=""  # Will be set to benchmarks/<timestamp> by default
DOCUMENT=""  # Will be auto-detected or provided
DATABASE_URL=""  # Will be set by --database flag or generated
SKIP_DB_SETUP=false  # Skip Docker PostgreSQL setup if --database provided
EXTRA_ARGS=()
USE_DEFAULT_OUTPUT=true  # Track if user provided custom output dir

# Function to validate paths against injection
validate_path() {
    local path="$1"
    local name="$2"
    
    # Check for dangerous characters that could be used for injection
    if [[ "$path" =~ [\;\|\&\$\`\(\)\{\}\<\>] ]]; then
        echo "Error: Invalid characters in $name path: $path"
        exit 1
    fi
    
    # Ensure path doesn't start with - (could be interpreted as option)
    if [[ "$path" == -* ]]; then
        echo "Error: $name path cannot start with '-': $path"
        exit 1
    fi
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --help|-h)
            show_help
            ;;
        --baseline)
            BASELINE="$2"
            shift 2
            ;;
        --output-dir)
            OUTPUT_DIR="$2"
            USE_DEFAULT_OUTPUT=false
            shift 2
            ;;
        --database)
            DATABASE_URL="$2"
            SKIP_DB_SETUP=true
            shift 2
            ;;
        --document-id|--max-retries|--retry-threshold|--target-chunk-tokens|--preceding-context-tokens|--summary-model|--embedding-model|--embedding-batch-size)
            # Pass-through options that take an argument
            EXTRA_ARGS+=("$1" "$2")
            shift 2
            ;;
        --*)
            # Other options (flags without arguments)
            EXTRA_ARGS+=("$1")
            shift
            ;;
        *)
            # First non-option argument is the document
            if [ -z "$DOCUMENT" ]; then
                DOCUMENT="$1"
            else
                # Additional positional arguments
                EXTRA_ARGS+=("$1")
            fi
            shift
            ;;
    esac
done

# Set default output directory if not provided
if [ "$USE_DEFAULT_OUTPUT" = true ]; then
    OUTPUT_DIR="benchmarks/${TIMESTAMP}"
    echo "Using timestamped output directory: $OUTPUT_DIR"
fi

# Check for default baseline if not provided
if [ -z "$BASELINE" ]; then
    # First check for previous run in benchmarks/latest
    if [ -f "benchmarks/latest/telemetry.json" ]; then
        BASELINE="benchmarks/latest/telemetry.json"
        echo "Using previous run as baseline: $BASELINE"
    elif [ -f "./telemetry.json" ]; then
        BASELINE="./telemetry.json"
        echo "Using baseline from current directory: $BASELINE"
    else
        # Try to find repository root (parent of worktrees directory if in a worktree)
        REPO_ROOT=""
        if [[ "$PWD" == */worktrees/* ]]; then
            # We're in a worktree, find the main repo
            REPO_ROOT=$(echo "$PWD" | sed 's|/worktrees/.*||')
        fi
        
        # Check repository root if different from current directory
        if [ -n "$REPO_ROOT" ] && [ "$REPO_ROOT" != "$PWD" ] && [ -f "$REPO_ROOT/telemetry.json" ]; then
            BASELINE="$REPO_ROOT/telemetry.json"
            echo "Using baseline from repository root: $BASELINE"
        else
            echo "Error: No baseline specified and no telemetry.json found"
            echo ""
            echo "Searched for telemetry.json in:"
            echo "  1. benchmarks/latest/telemetry.json (previous run)"
            echo "  2. ./telemetry.json (current directory)"
            if [ -n "$REPO_ROOT" ] && [ "$REPO_ROOT" != "$PWD" ]; then
                echo "  3. $REPO_ROOT/telemetry.json (repository root)"
            fi
            echo ""
            echo "For first run, either:"
            echo "  1. Create a baseline: python -m ragzoom.cli index <document> --telemetry telemetry.json"
            echo "  2. Specify an existing baseline: $0 --baseline <baseline.json> ..."
            echo ""
            echo "After first run, subsequent runs will automatically use the previous run as baseline."
            exit 1
        fi
    fi
fi

# Validate baseline path
validate_path "$BASELINE" "baseline"

if [ ! -f "$BASELINE" ]; then
    echo "Error: Baseline file '$BASELINE' does not exist"
    exit 1
fi

# Create output directory early if it doesn't exist
mkdir -p "$OUTPUT_DIR"

# Extract metadata from baseline
echo "Extracting configuration from baseline..."
DOCUMENT_ID=$(jq -r '.document_id // empty' "$BASELINE")
DOCUMENT_PATH=$(jq -r '.document_path // empty' "$BASELINE")

# Extract ONLY target_chunk_tokens from baseline for fair comparison
# All other settings should use current defaults from default_config.json
CONFIG=$(jq -r '.config // empty' "$BASELINE")
TARGET_CHUNK_TOKENS=""
if [ -n "$CONFIG" ] && [ "$CONFIG" != "null" ]; then
    TARGET_CHUNK_TOKENS=$(echo "$CONFIG" | jq -r '.target_chunk_tokens // empty')
    if [ -n "$TARGET_CHUNK_TOKENS" ]; then
        echo "  Extracted target_chunk_tokens from baseline: $TARGET_CHUNK_TOKENS"
        echo "  All other settings will use current defaults from default_config.json"
    fi
else
    echo "Warning: Could not extract config from baseline telemetry"
    echo "  The indexer will use default configuration"
fi

# Auto-detect document if not provided
if [ -z "$DOCUMENT" ]; then
    # First try to use document_path from telemetry (absolute path)
    if [ -n "$DOCUMENT_PATH" ] && [ -f "$DOCUMENT_PATH" ]; then
        DOCUMENT="$DOCUMENT_PATH"
        echo "  Using document path from baseline: $DOCUMENT"
    # Fall back to document_id in test_data for backward compatibility
    elif [ -n "$DOCUMENT_ID" ]; then
        echo "  Document ID from baseline: $DOCUMENT_ID"
        if [ -f "./test_data/$DOCUMENT_ID" ]; then
            DOCUMENT="./test_data/$DOCUMENT_ID"
            echo "  Auto-detected document: $DOCUMENT"
        else
            echo ""
            echo "Error: Cannot find document './test_data/$DOCUMENT_ID'"
            echo "Please provide document path as argument"
            exit 1
        fi
    else
        echo ""
        echo "Error: No document specified and could not extract document_id or document_path from baseline"
        echo "Please provide document path as argument"
        exit 1
    fi
fi

# Validate document path
validate_path "$DOCUMENT" "document"

# Set up file paths
TELEMETRY_FILE="$OUTPUT_DIR/telemetry.json"
LOG_FILE="$OUTPUT_DIR/log.txt"
VISUALIZATION_FILE="$OUTPUT_DIR/visualization.png"

# Generate unique database name for this benchmark run
BENCHMARK_DB_NAME="benchmark_${TIMESTAMP}"
DATABASE_NAME_FILE="$OUTPUT_DIR/benchmark_db.txt"

echo ""
echo "🚀 Starting indexing benchmark..."
echo "  Baseline: $BASELINE"
echo "  Document: $DOCUMENT"
echo "  Output directory: $OUTPUT_DIR"
if [ ${#EXTRA_ARGS[@]} -gt 0 ]; then
    echo "  Additional options: ${EXTRA_ARGS[@]}"
fi
echo ""

# Set up database - either use provided URL or create new one
if [ "$SKIP_DB_SETUP" = true ]; then
    echo "🗄️ Using provided database URL..."
    echo "  Database URL: $DATABASE_URL"
    echo ""
    
    # Save database info for reference (no cleanup needed for external DB)
    echo "external_database" > "$DATABASE_NAME_FILE"
    echo "$DATABASE_URL" >> "$DATABASE_NAME_FILE"
else
    # Ensure PostgreSQL is running and create benchmark database
    echo "🗄️ Setting up PostgreSQL benchmark database..."

    # Create database and capture the returned URL with credentials
    # Use environment variable to avoid shell injection
    BENCHMARK_DB_ENV_NAME="$BENCHMARK_DB_NAME" python -c "
from ragzoom.docker_postgres import DockerPostgres
from ragzoom.db_utils import create_temp_database
import os, sys
try:
    dp = DockerPostgres()
    dp.ensure_running()
    db_name = os.environ['BENCHMARK_DB_ENV_NAME']
    url = create_temp_database(db_name)
    print(url)
except Exception as e:
    print(f'Error: {e}', file=sys.stderr)
    sys.exit(1)
" > /tmp/db_setup_$$.out 2> /tmp/db_setup_$$.err

    # Check if database creation succeeded and capture output properly
    if [ $? -eq 0 ]; then
        DATABASE_URL=$(cat /tmp/db_setup_$$.out)
        rm -f /tmp/db_setup_$$.out /tmp/db_setup_$$.err
    else
        echo "❌ Failed to set up PostgreSQL database:"
        cat /tmp/db_setup_$$.err >&2
        rm -f /tmp/db_setup_$$.out /tmp/db_setup_$$.err
        exit 1
    fi

    # Track the database for cleanup
    CREATED_DB_NAME="$BENCHMARK_DB_NAME"

    # Save database name and URL for reference
    echo "$BENCHMARK_DB_NAME" > "$DATABASE_NAME_FILE"
    echo "$DATABASE_URL" >> "$DATABASE_NAME_FILE"

    echo "✅ Created benchmark database: $BENCHMARK_DB_NAME"
    echo "  Database URL: $DATABASE_URL"
    echo ""
fi

# Run indexing with telemetry
# Implicitly adds: --telemetry <file> --validate --debug --no-progress
echo "📝 Running indexing with telemetry..."

# Build command args
INDEX_ARGS=(
    "$DOCUMENT"
    --telemetry "$TELEMETRY_FILE"
    --database "$DATABASE_URL"
    --validate
    --debug
    --no-progress
)

# Add target_chunk_tokens if we extracted it from baseline
# This ensures fair comparison while using current defaults for everything else
if [ -n "$TARGET_CHUNK_TOKENS" ]; then
    INDEX_ARGS+=(--target-chunk-tokens "$TARGET_CHUNK_TOKENS")
fi

# Add any extra arguments
if [ ${#EXTRA_ARGS[@]} -gt 0 ]; then
    INDEX_ARGS+=("${EXTRA_ARGS[@]}")
fi

python -m ragzoom.cli index "${INDEX_ARGS[@]}" 2>&1 | tee "$LOG_FILE"

# Check if indexing succeeded
if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "❌ Indexing failed. Check $LOG_FILE for details."
    exit 1
fi

echo ""
echo "✅ Indexing completed. Telemetry saved to $TELEMETRY_FILE"
echo ""

# Generate comparison report and visualization
echo "📊 Generating comparison report and visualization..."

# Generate markdown comparison report
echo "  Generating comparison report..."
# Note: compare command returns exit code 1 when regression detected, but still generates report
# Temporarily disable exit on error for this command
set +e
python -m ragzoom.telemetry_cli compare \
    "$BASELINE" \
    "$TELEMETRY_FILE" \
    > "$OUTPUT_DIR/comparison.md" 2>&1
COMPARE_EXIT_CODE=$?
set -e

if [ $COMPARE_EXIT_CODE -eq 0 ]; then
    echo "  ✅ Comparison report saved to $OUTPUT_DIR/comparison.md"
elif [ $COMPARE_EXIT_CODE -eq 1 ]; then
    echo "  ⚠️ Comparison report saved to $OUTPUT_DIR/comparison.md (regression detected)"
else
    echo "  ❌ Comparison failed. Check $OUTPUT_DIR/comparison.md for details."
fi

# Generate CI-friendly summary
echo "  Generating CI summary..."
CI_SUMMARY_FILE="$OUTPUT_DIR/ci-summary.json"
cat > "$CI_SUMMARY_FILE" <<EOF
{
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "exit_code": $COMPARE_EXIT_CODE,
  "regression_detected": $([ $COMPARE_EXIT_CODE -eq 1 ] && echo "true" || echo "false"),
  "comparison_succeeded": $([ $COMPARE_EXIT_CODE -le 1 ] && echo "true" || echo "false"),
  "telemetry_file": "$TELEMETRY_FILE",
  "comparison_file": "$OUTPUT_DIR/comparison.md",
  "baseline_file": "$BASELINE"
}
EOF
echo "  ✅ CI summary saved to $CI_SUMMARY_FILE"

# Generate visualization (optional - check for dependencies)
echo "  Checking for visualization dependencies..."
if python -c "import matplotlib, seaborn, pandas" 2>/dev/null; then
    echo "  Generating visualization..."
    # Capture exit code without affecting error handling
    python -m ragzoom.telemetry_cli visualize \
        "$BASELINE" \
        "$TELEMETRY_FILE" \
        --output "$VISUALIZATION_FILE" \
        > "$OUTPUT_DIR/visualization.log" 2>&1 || VIZ_EXIT_CODE=$?
    
    # Default to 0 if not set (success case)
    VIZ_EXIT_CODE=${VIZ_EXIT_CODE:-0}
    
    if [ $VIZ_EXIT_CODE -eq 0 ]; then
        echo "  ✅ Visualization saved to $VISUALIZATION_FILE"
    else
        echo "  ❌ Visualization failed. Check $OUTPUT_DIR/visualization.log for details."
    fi
else
    echo "  ⚠️ Skipping visualization (missing dependencies: matplotlib/seaborn/pandas)"
    echo "     Install with: pip install ragzoom[telemetry]"
fi

echo ""

# Update latest symlink if using default output structure
if [ "$USE_DEFAULT_OUTPUT" = true ]; then
    # Create benchmarks directory if it doesn't exist
    mkdir -p benchmarks
    
    # Update the latest symlink
    # Use relative path for the symlink target to make it portable
    (cd benchmarks && ln -sfn "${TIMESTAMP}" latest)
    
    echo "📎 Updated benchmarks/latest symlink → $OUTPUT_DIR"
    echo ""
fi

echo "🎉 Benchmark complete! Results:"
echo "  - Database: $DATABASE_URL (details saved in $DATABASE_NAME_FILE)"
echo "  - Telemetry: $OUTPUT_DIR/telemetry.json"
echo "  - Log: $OUTPUT_DIR/log.txt"
echo "  - Comparison report: $OUTPUT_DIR/comparison.md"
echo "  - CI summary: $OUTPUT_DIR/ci-summary.json"
echo "  - Visualization: $OUTPUT_DIR/visualization.png"
echo ""
# On successful completion, don't auto-cleanup - leave database for debugging
CREATED_DB_NAME=""  # Clear the cleanup variable to prevent auto-cleanup

if [ "$SKIP_DB_SETUP" != true ]; then
    echo "💡 Database cleanup: The benchmark database '$BENCHMARK_DB_NAME' is left intact for debugging."
    echo "   To clean up manually: CLEANUP_DB_NAME='$BENCHMARK_DB_NAME' python -c 'from ragzoom.db_utils import drop_temp_database; import os; drop_temp_database(os.environ[\"CLEANUP_DB_NAME\"])'"
fi

if [ "$USE_DEFAULT_OUTPUT" = true ]; then
    echo ""
    echo "💡 Quick access via: benchmarks/latest/"
    echo "   View results: open benchmarks/latest/visualization.png"
    echo "   Next iteration: scripts/run-indexing-benchmarks"
fi