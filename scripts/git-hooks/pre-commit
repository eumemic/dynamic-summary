#!/bin/bash
# Git pre-commit hook for RagZoom
# Runs tests (excluding slow ones) and linting checks

echo "Running pre-commit checks..."

# Find the repository root (works from .git/hooks/ or worktree hooks)
GIT_ROOT="$(git rev-parse --show-toplevel)"

# Run all checks using the common script
# Don't skip any checks for git commits
"$GIT_ROOT/scripts/run-checks.sh"
RESULT=$?

# Get list of modified Python files to re-add after formatting
modified_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

# Re-add any files that were auto-formatted
if [ -n "$modified_files" ]; then
    git add $modified_files 2>/dev/null
fi

echo ""
if [ $RESULT -eq 0 ]; then
    echo "✅ All pre-commit checks passed!"
    exit 0
else
    echo "❌ Pre-commit checks failed! See above for details."
    # Exit with 1 for git (not 2)
    exit 1
fi