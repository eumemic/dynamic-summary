# RagZoom Configuration
# Copy this file to .env and fill in your values
#
# For production (global install), place at: ~/.config/ragzoom/.env
# For development, place in the project root (takes priority over ~/.config/ragzoom/.env)

# Required: OpenAI API Key
OPENAI_API_KEY=your-key-here

# Optional: Override default configuration
# RAGZOOM_BUDGET_TOKENS=8000
# RAGZOOM_LEAF_TOKENS=200
# RAGZOOM_MMR_LAMBDA=0.7
# RAGZOOM_EMBEDDING_MODEL=text-embedding-3-small
# RAGZOOM_SUMMARY_MODEL=gpt-4o
# RAGZOOM_LOG_LEVEL=INFO

# Optional: Database connection (defaults to auto-managed Docker PostgreSQL)
# RAGZOOM_DATABASE_URL=postgresql+psycopg://localhost/ragzoom

# Optional: Disable auto-Docker PostgreSQL (requires manual PostgreSQL setup)  
# RAGZOOM_NO_DOCKER=1