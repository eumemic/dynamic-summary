#!/bin/bash
# Git pre-commit hook for RagZoom
# Runs tests (excluding slow ones) and linting checks in parallel

echo "Running pre-commit checks..."

# Get the list of modified Python files
modified_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$')

# Function to run tests
run_tests() {
    echo "[Tests] Starting..."
    # Run quietly first, capture output
    local tmpfile=$(mktemp)
    pytest tests/ -q --tb=short -m "not slow and not integration and not benchmark" -n 8 --no-header > "$tmpfile" 2>&1
    local result=$?
    if [ $result -ne 0 ]; then
        echo "[Tests] ❌ Failed!"
        # Show full output on failure
        cat "$tmpfile"
        rm -f "$tmpfile"
        return 1
    else
        echo "[Tests] ✅ Passed!"
        return 0
    fi
}

# Function to run ruff
run_ruff() {
    if command -v ruff &> /dev/null; then
        if [ -n "$modified_files" ]; then
            echo "[Ruff] Starting..."
            # Run with quiet flag, capture output
            local tmpfile=$(mktemp)
            ruff check ragzoom/ tests/ --fix --quiet > "$tmpfile" 2>&1
            local result=$?
            if [ $result -ne 0 ]; then
                echo "[Ruff] ❌ Found issues that could not be auto-fixed."
                # Show full output on failure
                cat "$tmpfile"
                rm -f "$tmpfile"
                return 1
            else
                echo "[Ruff] ✅ Passed!"
                return 0
            fi
        else
            echo "[Ruff] Skipped (no Python files)"
            return 0
        fi
    fi
    return 0
}

# Function to run black
run_black() {
    if command -v black &> /dev/null; then
        if [ -n "$modified_files" ]; then
            echo "[Black] Starting..."
            # Run with quiet flag, capture output
            local tmpfile=$(mktemp)
            black ragzoom/ tests/ --quiet > "$tmpfile" 2>&1
            local result=$?
            if [ $result -ne 0 ]; then
                echo "[Black] ❌ Formatting failed."
                # Show full output on failure
                cat "$tmpfile"
                rm -f "$tmpfile"
                return 1
            else
                echo "[Black] ✅ Passed!"
                return 0
            fi
        else
            echo "[Black] Skipped (no Python files)"
            return 0
        fi
    fi
    return 0
}

# Function to run mypy
run_mypy() {
    if command -v dmypy &> /dev/null || command -v mypy &> /dev/null; then
        if [ -n "$modified_files" ]; then
            echo "[Mypy] Starting..."
            if command -v dmypy &> /dev/null; then
                # Use dmypy run which starts daemon if needed and runs check
                dmypy run -- ragzoom --ignore-missing-imports --no-error-summary --check-untyped-defs
                local result=$?
            else
                # Fallback to regular mypy if dmypy not available
                mypy ragzoom --ignore-missing-imports --no-error-summary --check-untyped-defs
                local result=$?
            fi
            if [ $result -ne 0 ]; then
                echo "[Mypy] ❌ Failed! Type errors found"
                return $result  # Return the actual error code
            else
                echo "[Mypy] ✅ Passed!"
                return 0
            fi
        else
            echo "[Mypy] Skipped (no Python files)"
            return 0
        fi
    fi
    return 0
}

# Function to run jscpd
run_jscpd() {
    if command -v npx &> /dev/null; then
        if [ -n "$modified_files" ]; then
            echo "[JSCPD] Starting..."
            # Run with silent flag, capture output
            local tmpfile=$(mktemp)
            npx jscpd@latest ragzoom/ --exitCode 1 > "$tmpfile" 2>&1
            local result=$?
            if [ $result -ne 0 ]; then
                echo "[JSCPD] ❌ Code duplication found!"
                # Show full output on failure
                cat "$tmpfile"
                rm -f "$tmpfile"
                return 1
            else
                echo "[JSCPD] ✅ Passed!"
                return 0
            fi
        else
            echo "[JSCPD] Skipped (no Python files)"
            return 0
        fi
    else
        echo "[JSCPD] Skipped (npx not available)"
        return 0
    fi
}

# Create temporary files for storing results
tmpdir=$(mktemp -d)
# Set up trap to clean up temp files and kill any background processes on exit
cleanup() {
    # Kill any background processes that might still be running
    kill $pid_tests $pid_mypy $pid_ruff $pid_black $pid_jscpd 2>/dev/null || true
    # Clean up temp directory
    rm -rf "$tmpdir"
}
trap cleanup EXIT INT TERM

# Capture output from each tool
(run_tests > "$tmpdir/tests.output" 2>&1; echo $? > "$tmpdir/tests.result") &
pid_tests=$!

(run_mypy > "$tmpdir/mypy.output" 2>&1; echo $? > "$tmpdir/mypy.result") &
pid_mypy=$!

(run_ruff > "$tmpdir/ruff.output" 2>&1; echo $? > "$tmpdir/ruff.result") &
pid_ruff=$!

(run_black > "$tmpdir/black.output" 2>&1; echo $? > "$tmpdir/black.result") &
pid_black=$!

(run_jscpd > "$tmpdir/jscpd.output" 2>&1; echo $? > "$tmpdir/jscpd.result") &
pid_jscpd=$!

# Wait for all background jobs to complete
echo ""
wait $pid_tests $pid_mypy $pid_ruff $pid_black $pid_jscpd

# Display output in predictable order: tests, mypy, ruff, black, jscpd
cat "$tmpdir/tests.output" 2>/dev/null
cat "$tmpdir/mypy.output" 2>/dev/null
cat "$tmpdir/ruff.output" 2>/dev/null
cat "$tmpdir/black.output" 2>/dev/null
cat "$tmpdir/jscpd.output" 2>/dev/null

# Re-add any files that were auto-formatted
if [ -n "$modified_files" ]; then
    git add $modified_files 2>/dev/null
fi

# Check results
failed=0

# Check test results
if [ -f "$tmpdir/tests.result" ] && [ "$(cat "$tmpdir/tests.result")" -ne 0 ]; then
    failed=1
fi

# Check ruff results
if [ -f "$tmpdir/ruff.result" ] && [ "$(cat "$tmpdir/ruff.result")" -ne 0 ]; then
    failed=1
fi

# Check black results
if [ -f "$tmpdir/black.result" ] && [ "$(cat "$tmpdir/black.result")" -ne 0 ]; then
    failed=1
fi

# Check mypy results
if [ -f "$tmpdir/mypy.result" ] && [ "$(cat "$tmpdir/mypy.result")" -ne 0 ]; then
    failed=1
fi

# Check jscpd results
if [ -f "$tmpdir/jscpd.result" ] && [ "$(cat "$tmpdir/jscpd.result")" -ne 0 ]; then
    failed=1
fi

echo ""
if [ $failed -eq 0 ]; then
    echo "✅ All pre-commit checks passed!"
    exit 0
else
    echo "❌ Pre-commit checks failed! See above for details."
    exit 1
fi