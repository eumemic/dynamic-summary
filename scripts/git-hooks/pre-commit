#!/bin/bash
# Git pre-commit hook for RagZoom
# Simply runs all tests - let pytest handle test discovery

# Get modified Python files
modified_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$')

if [ -z "$modified_files" ]; then
    echo "No Python files modified, skipping tests"
    exit 0
fi

echo "Running tests..."

# Run all tests using the standard test script
./test_quick.sh

# Capture the exit code
test_result=$?

if [ $test_result -ne 0 ]; then
    echo "Tests failed! Commit aborted."
    exit 1
fi

# Also run linting on modified Python files
echo "Running linting checks..."
for file in $modified_files; do
    if [[ "$file" == *.py ]]; then
        # Run ruff check
        ruff check "$file" || exit 1
    fi
done

echo "All checks passed!"
exit 0