#!/bin/bash
# Sync all OpenClaw sessions to RagZoom
# Reads session mappings from sessions.json

set -e

cd /Users/jarvis/code/dynamic-summary
source .venv/bin/activate

SESSIONS_DIR="$HOME/.openclaw/agents/main/sessions"
SESSIONS_JSON="$SESSIONS_DIR/sessions.json"

# Parse sessions.json and sync each session
python3 << 'EOF'
import json
import subprocess
import os

sessions_dir = os.path.expanduser("~/.openclaw/agents/main/sessions")
sessions_json = f"{sessions_dir}/sessions.json"

with open(sessions_json) as f:
    sessions = json.load(f)

for session_key, session_data in sessions.items():
    session_id = session_data.get("sessionId")
    if not session_id:
        continue
    
    jsonl_path = f"{sessions_dir}/{session_id}.jsonl"
    if not os.path.exists(jsonl_path):
        continue
    
    # Run ragzoom-openclaw sync
    result = subprocess.run(
        ["ragzoom-openclaw", "sync", jsonl_path, "--document-id", session_key],
        capture_output=True,
        text=True
    )
    
    # Print output
    if result.stdout.strip():
        print(result.stdout.strip())
EOF
