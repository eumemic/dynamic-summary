#!/bin/bash
# Git pre-push hook for RagZoom
# Runs full test suite before pushing to remote

echo "Running full test suite before push..."

# Run all tests with slightly more verbose output
pytest tests/ --tb=short

# Capture the exit code
test_result=$?

if [ $test_result -ne 0 ]; then
    echo ""
    echo "❌ Tests failed! Push aborted."
    echo "Fix the failing tests before pushing."
    exit 1
fi

echo ""
echo "✅ All tests passed!"

# Optional: Run type checking
if command -v mypy &> /dev/null; then
    echo "Running type checking..."
    mypy ragzoom --ignore-missing-imports --no-error-summary 2>/dev/null
    if [ $? -ne 0 ]; then
        echo "⚠️  Type checking found issues (push will continue)"
    else
        echo "✅ Type checking passed!"
    fi
fi

echo ""
echo "Ready to push!"
exit 0